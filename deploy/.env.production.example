# =====================================================================
# .env.production.example — Template para producción
# =====================================================================
# IMPORTANTE: copiá este archivo a `.env` en producción y completá los
# valores reales. NO commitees el .env real al repo.
#
# Ubicación esperada en prod: /srv/taller-mecanico/taller_mecanico/.env
# Permisos: chmod 600 + chown taller:taller
# =====================================================================

# ---------------------------------------------------------------------
# DJANGO CORE
# ---------------------------------------------------------------------
# Generá con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=GENERA_UN_SECRET_KEY_RANDOM_DE_AL_MENOS_50_CARS

# OBLIGATORIO False en prod. NO cambiar.
DEBUG=False

# Hosts permitidos. Incluí TU dominio + el wildcard + 127.0.0.1 para health checks.
# Los custom domains de clientes se manejan por la tabla `Domain` de django-tenants
# y NO necesitan estar en ALLOWED_HOSTS si terminan en .gctorque.com.
# Para custom domains de terceros (ej. tallerjuan.com.ar), agregalos acá tambien.
ALLOWED_HOSTS=gctorque.com,.gctorque.com,127.0.0.1

# URLs públicas — usadas para links de activación, magic-link, etc.
FRONTEND_URL=https://gctorque.com
BACKEND_URL=https://gctorque.com

# Dominio raíz de subdomains de tenants — usado para CORS regex y CSRF.
# Sin protocolo ni subdomain (ej. "gctorque.com", NO "https://*.gctorque.com").
PROD_DOMAIN=gctorque.com

# ---------------------------------------------------------------------
# BASE DE DATOS — PostgreSQL local en la VM
# ---------------------------------------------------------------------
DB_ENGINE=django_tenants.postgresql_backend
DB_NAME=taller_mecanico
DB_USER=taller_meca
DB_PASSWORD=GENERA_UN_PASSWORD_FUERTE_DE_AL_MENOS_20_CARS
DB_HOST=127.0.0.1
DB_PORT=5432

# ---------------------------------------------------------------------
# CELERY / REDIS
# ---------------------------------------------------------------------
# Redis local en la VM (recomendado). Si querés RabbitMQ, cambiá la URL.
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=django-db

# ---------------------------------------------------------------------
# EMAIL — Gmail SMTP (App Password) o SendGrid/Mailgun en escala
# ---------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=no-reply@gctorque.com
EMAIL_HOST_PASSWORD=APP_PASSWORD_GMAIL_AQUI
DEFAULT_FROM_EMAIL=no-reply@gctorque.com
EMAIL_TIMEOUT=15

# ---------------------------------------------------------------------
# WHATSAPP (Twilio)
# ---------------------------------------------------------------------
# Cambiar a `twilio` cuando tengas la cuenta lista para producción.
WHATSAPP_BACKEND=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
WHATSAPP_DEFAULT_COUNTRY_CODE=502

# ---------------------------------------------------------------------
# Gunicorn (opcional — defaults razonables ya configurados)
# ---------------------------------------------------------------------
# GUNICORN_LOGLEVEL=info

# Copia este archivo a `.env` y completá los valores reales.
# NUNCA commitees tu `.env` real — contiene secrets.

# =====================================================================
# DJANGO CORE
# =====================================================================
SECRET_KEY=cambiame-en-prod-a-algo-random-de-al-menos-50-caracteres
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.localhost

# =====================================================================
# URLs DEL SISTEMA (PR #39 — centralizadas)
# =====================================================================
# SPA React (el frontend con Vite, puerto 5173 por default).
FRONTEND_URL=http://localhost:5173
# Backend Django (para links de activación, magic-link, etc.).
BACKEND_URL=http://localhost:8000

# =====================================================================
# BASE DE DATOS — PostgreSQL
# =====================================================================
# Defaults apuntan al `infra/postgres/docker-compose.yml`. Si arrancás el
# Postgres con `cd infra/postgres && docker compose up -d`, no hace falta
# tocar nada acá.
DB_ENGINE=django.db.backends.postgresql
DB_NAME=taller_mecanico
DB_USER=taller_meca
DB_PASSWORD=taller_meca_dev
DB_HOST=localhost
DB_PORT=5432

# =====================================================================
# EMAIL (SMTP)
# =====================================================================
# Para dev local usá el console backend (imprime el correo en terminal).
# Para prod / staging usá smtp backend y credenciales reales.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=fixfastpro@gmail.com
EMAIL_HOST_PASSWORD=pon-aqui-la-app-password-de-gmail
DEFAULT_FROM_EMAIL=fixfastpro@gmail.com

# =====================================================================
# WHATSAPP (Twilio)
# =====================================================================
# `mock` → no envía, loguea. `twilio` → envía real con cuenta de abajo.
WHATSAPP_BACKEND=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
WHATSAPP_DEFAULT_COUNTRY_CODE=502

# =====================================================================
# CELERY / REDIS (opcional en dev; puede estar vacío y Celery no arranca)
# =====================================================================
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

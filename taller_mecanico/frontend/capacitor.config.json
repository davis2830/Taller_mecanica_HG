{
  "appId": "com.gctorque.app",
  "appName": "GCTorque",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "allowNavigation": ["*.gctorque.com"]
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 2000,
      "backgroundColor": "#1e293b",
      "showSpinner": true,
      "spinnerColor": "#3b82f6"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#1e293b"
    }
  }
}
